

@using GymeManagementBLL.ViewModels.MembershipsViewModels
@model CreateMembershipViewModel

@{
ViewData["Title"] = "Create Membership";
}

<!-- Success Message -->

@if (TempData["SuccessMessege"] is not null)
{ <div id="Alert" class="alert alert-success alert-dismissible fade show"> <i class="bi bi-check-circle-fill me-2"></i>
@TempData["SuccessMessege"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button> </div>
}

<!-- Error Message -->

@if (TempData["ErrorMessege"] is not null)
{ <div id="Alert" class="alert alert-danger alert-dismissible fade show"> <i class="bi bi-exclamation-triangle-fill me-2"></i>
@TempData["ErrorMessege"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button> </div>
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h4>@ViewData["Title"]</h4>
                </div>

```
            <div class="card-body">

                <!-- Validation Summary -->
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Member -->
                    <div class="mb-3">
                        <label class="form-label">Member</label>
                        <select asp-for="MemberId" class="form-select" required>
                            <option value="" disabled selected>-- Select Member --</option>
                            @foreach (var item in Model.Members)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        </select>
                        <span asp-validation-for="MemberId" class="text-danger"></span>
                    </div>

                    <!-- Plan -->
                    <div class="mb-3">
                        <label class="form-label">Plan</label>
                        <select asp-for="PlanId" class="form-select" required>
                            <option value="" disabled selected>-- Select Plan --</option>
                            @foreach (var item in Model.Plans)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        </select>
                        <span asp-validation-for="PlanId" class="text-danger"></span>
                    </div>

                    <!-- Buttons -->
                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary">
                            Create Membership
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            Cancel
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
```

</div>

@section Scripts { <partial name="_ValidationScriptsPartial" />

```
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const alertBox = document.getElementById("Alert");
        if (alertBox) {
            setTimeout(() => {
                alertBox.style.transition = "opacity 0.5s ease";
                alertBox.style.opacity = "0";
                setTimeout(() => alertBox.remove(), 500);
            }, 2000);
        }
    });
</script>
