@model IEnumerable<SessionViewModel>

@{
    var upcoming = Model.Where(x => x.Status == "UpComing").ToList();
    var ongoing = Model.Where(x => x.Status == "OnGoing").ToList();
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-danger">@TempData["Success"]</div>
}

<div class="container">

    <!-- 🔵 Upcoming Sessions -->
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-primary mb-0">Upcoming Sessions</h2>
            <p class="text-muted">Session Valid For Booking</p>
        </div>
    </header>

    <div class="row g-4">

        @if (upcoming.Any())
        {
            @foreach (var session in upcoming)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">

                        <div class="card-header text-white py-3 bg-primary">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">
                                    <i class="bi bi-calendar-event me-2"></i>
                                    @session.CategoryName
                                </h5>
                                <span class="badge bg-light text-dark">Upcoming</span>
                            </div>
                        </div>

                        <div class="card-body">

                            <p class="text-muted mb-3">@session.Description</p>

                            <div class="mb-2">
                                <strong>Trainer:</strong> @session.TrainerName
                            </div>

                            <div class="mb-2">
                                <strong>Date:</strong> @session.DateDisplay
                            </div>

                            <div class="mb-2">
                                <strong>Time:</strong> @session.TimeRange
                            </div>

                            <div class="mb-2">
                                <strong>Duration:</strong> @session.Duration
                            </div>

                            <div>
                                <strong>Capacity:</strong>
                                @(session.Capacity - session.AvailableSlots)/ @session.Capacity
                            </div>

                        </div>

                        <div class="card-footer bg-white border-0">
                            <div class="d-grid gap-2">
                                <a asp-action="GetMembersForUpcomingSession"
                                   asp-route-sessionId="@session.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye me-1"></i> View Members
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-4">
                <h5 class="text-muted">No Upcoming Sessions</h5>
            </div>
        }

    </div>


    <!-- 🟢 Ongoing Sessions -->
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-success mb-0">Ongoing Sessions</h2>
            <p class="text-muted">Session Valid For Attendance</p>
        </div>
    </header>

    <div class="row g-4">

        @if (ongoing.Any())
        {
            @foreach (var session in ongoing)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">

                        <div class="card-header text-white py-3 bg-success">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">
                                    <i class="bi bi-calendar-event me-2"></i>
                                    @session.CategoryName
                                </h5>
                                <span class="badge bg-light text-dark">Ongoing</span>
                            </div>
                        </div>

                        <div class="card-body">

                            <p class="text-muted mb-3">@session.Description</p>

                            <div class="mb-2">
                                <strong>Trainer:</strong> @session.TrainerName
                            </div>

                            <div class="mb-2">
                                <strong>Date:</strong> @session.DateDisplay
                            </div>

                            <div class="mb-2">
                                <strong>Time:</strong> @session.TimeRange
                            </div>

                            <div class="mb-2">
                                <strong>Duration:</strong> @session.Duration
                            </div>

                            <div>
                                <strong>Capacity:</strong>
                                @(session.Capacity - session.AvailableSlots) / @session.Capacity
                            </div>

                        </div>

                        <div class="card-footer bg-white border-0">
                            <div class="d-grid gap-2">
                                <a asp-action="GetMembersForOngoingSessions"
                                   asp-route-sessionId="@session.Id"
                                   class="btn btn-outline-success btn-sm">
                                    <i class="bi bi-eye me-1"></i> View Members
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-4">
                <h5 class="text-muted">No Ongoing Sessions</h5>
            </div>
        }

    </div>


    <!-- ❌ No Sessions -->
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No Sessions Available</h4>
            <p class="text-muted">Create training session first to get started</p>
        </div>
    }

</div>