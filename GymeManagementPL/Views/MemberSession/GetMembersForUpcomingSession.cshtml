@using GymeManagementBLL.ViewModels.MemberSession
@model IEnumerable<MemberSessionViewModel>

@{
    ViewData["Title"] = "Session Members";
    var sessionId = ViewBag.SessionId; 
 }

@if (TempData["SuccessMessege"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessege"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessege"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessege"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<header class="bg-primary text-white rounded-3 p-4 shadow-sm mt-5 mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-1 fw-semibold">Session Members</h2>
            <p class="mb-0 text-light opacity-75">Members That Already Book Session</p>
        </div>

        <div class="text-end">
            <a asp-action="Create" asp-route-sessionId="@sessionId" class="btn btn-light">
                <i class="fas fa-plus me-1"></i> New Booking
            </a>
        </div>
    </div>
</header>

<div class="card shadow-sm">
    <div class="card-body">

        @if (Model != null && Model.Any())
        {
            <table class="table table-striped text-center">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Booking Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MemberName</td>
                            <td>@item.BookingDateDisplay</td>

                            <td>
                                <form asp-action="Cancel" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="memberSessionId" value="@item.MemberSessionId" />

                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Are you sure you want to cancel this booking?');">
                                        Cancel
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-5">
                <h4 class="text-muted">No Bookings Available</h4>
                <p class="text-muted">Add your first booking to get started</p>
            </div>
        }

    </div>

    <div class="m-3">
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>

@section Scripts
{
    <script>
        setTimeout(() => {
            document.querySelectorAll('.alert').forEach(x => x.remove());
        }, 2000);
    </script>
}