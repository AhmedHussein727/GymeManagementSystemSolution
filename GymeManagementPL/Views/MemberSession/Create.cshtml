@using GymeManagementBLL.ViewModels.MemberSession
@model CreateMemberSessionViewModel

<h2 class="mt-4">Create New Booking</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<form asp-action="Create" method="post">

    @Html.AntiForgeryToken()

    <!-- Hidden SessionId -->
    <input type="hidden" asp-for="SessionId" />

    <div class="card mt-3">
        <div class="card-header">
            <h5 class="mb-0">Booking Information</h5>
        </div>

        <div class="card-body">

            <!-- Member Dropdown -->
            <div class="mb-3">
                <label asp-for="MemberId" class="form-label"></label>

                <select asp-for="MemberId" class="form-select" id="MemberId">
                    <option value="">-- Select Member --</option>

                    @foreach (var member in Model.Members)
                    {
                        <option value="@member.Id">@member.Name</option>
                    }
                </select>

                <span asp-validation-for="MemberId" class="text-danger"></span>
            </div>

        </div>

        <div class="card-footer d-flex gap-2">

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Create Booking
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>

        </div>
    </div>
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            $('#MemberId').select2({
                placeholder: "Select a member",
                allowClear: true,
                width: '100%'
            });
        });
    </script>
}