@using GymeManagementBLL.ViewModels.TrainerViewMofels
@using GymeManagementDAL.Entities.Enums
@model TrainerToUpdateViewModel

<div class="container">
    <main role="main" class="pb-3">

        <div class="container mt-4">
            <header class="mb-4">
                <h3 class="text-primary-color">Edit Trainer</h3>
                <p class="text-muted">Update trainer information</p>
            </header>

            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <div class="mb-4 pb-3 border-bottom">
                                <small class="text-muted d-block mb-1">Editing Profile For</small>
                                <h4 class="mb-0 text-black">@Model.Name</h4>
                            </div>
                            @Html.ValidationMessage("Data Missed",new{@class="text-danger"})

                            <form asp-action="Edit" method="post">
                                <input asp-for="Name" hidden/>
                                <!-- Personal Information -->
                                <div class="section-header mb-3">
                                    <h5 class="text-primary fw-bold">Personal Information</h5>
                                    <hr class="mt-2">
                                </div>
                                <div class="row g-3 mb-4">


                                    <div class="col-md-6">
                                        <label asp-for="EmailAddress" class="form-label"></label>
                                        <input asp-for="EmailAddress" type="text" class="form-control" />
                                        <span asp-validation-for="EmailAddress" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label asp-for="PhoneNumber" class="form-label"></label>
                                        <input asp-for="PhoneNumber" type="text" class="form-control" />
                                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="BuildingNumber" class="form-label"></label>
                                        <input asp-for="BuildingNumber" type="text" class="form-control" />
                                        <span asp-validation-for="BuildingNumber" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Street" class="form-label"></label>
                                        <input asp-for="Street" type="text" class="form-control" />
                                        <span asp-validation-for="Street" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="City" class="form-label"></label>
                                        <input asp-for="City" type="text" class="form-control" />
                                        <span asp-validation-for="City" class="text-danger"></span>
                                    </div>
                                </div>

                                <!-- Professional Information -->
                                <div class="section-header mb-3">
                                    <h5 class="text-primary fw-bold">Professional Information</h5>
                                    <hr class="mt-2">
                                </div>
                                <div class="row g-3">

                                    <div class="col-12">
                                        <label asp-for="Specialities" class="form-label fw-semibold"> </label>
                                        <select asp-for="Specialities" asp-items="@Html.GetEnumSelectList<Specialities>()" class="form-select">
                                            <option value="">---select Specialities---</option>
                                        </select>
                                        <span asp-validation-for="Specialities" class="text-danger"></span>   
                                      
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                                    <a asp-action="Index" class="btn btn-outline">
                                        <i class="bi bi-arrow-left me-1"></i>Cancel
                                    </a>
                                    <button type="submit" class="btn btn-fill">
                                        <i class="bi bi-check-lg me-1"></i>Update Trainer
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>


    </main>
</div>
@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}

